        <mxCell id="eks" value="EKS Cluster muoidv-eks  v1.34 (control plane managed AWS)&#10;• MNG: t3.medium × 2-3 node (1/AZ private)  • Add-ons: vpc-cni / coredns / kube-proxy / ebs-csi" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;verticalAlign=top;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="290" y="455" width="780" height="60" as="geometry" />
        </mxCell>

        <mxCell id="ns-kube" value="ns: kube-system&#10;• AWS Load Balancer Controller (Helm, IRSA SA: aws-load-balancer-controller)&#10;• EBS CSI Driver (Add-on)  • StorageClass gp3 (default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="530" width="780" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ns-db" value="ns: database&#10;• Bitnami PostgreSQL (StatefulSet 1 replica + PVC gp3)&#10;• pgAdmin4 + Ingress ALB → pgadmin.muoidv.do2602.click" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="600" width="780" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ns-app" value="ns: app&#10;• tvtien-chart (helm create) — nginx sample → sample.muoidv.do2602.click&#10;• vue-nodejs CMS (build qua Jenkins)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="670" width="780" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ns-cicd" value="ns: cicd&#10;• Jenkins (Helm chart) + PVC + Ingress ALB → jenkins.muoidv.do2602.click&#10;• Plugin Git/GitHub/Kubernetes/Docker  • Cred: GitHub PAT, AWS AK, kubeconfig" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="740" width="780" height="55" as="geometry" />
        </mxCell>

        <mxCell id="ns-mon" value="ns: monitoring (BONUS)&#10;• kube-prometheus-stack (Prometheus + Grafana + Alertmanager + node-exporter + kube-state)&#10;• Grafana Ingress ALB → grafana.muoidv.do2602.click  • 30 dashboard built-in" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="810" width="780" height="60" as="geometry" />
        </mxCell>

        <mxCell id="iam" value="IAM Roles &amp; OIDC&#10;• EKS Cluster Role  • MNG Node Role (Worker+CNI+ECR+SSM)&#10;• OIDC Provider (cluster issuer)&#10;• IRSA: LBC, EBS CSI, ExternalDNS (optional)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="290" y="890" width="780" height="60" as="geometry" />
